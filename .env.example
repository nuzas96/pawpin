# ---------------------------------------------------------------------------
# PawPin environment variables — EXAMPLE ONLY. Copy to .env.local and fill in.
# NEVER commit real secrets. .env.local is git-ignored.
# ---------------------------------------------------------------------------

# Public Supabase project URL (safe to expose to the browser).
# Supabase Dashboard > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose; RLS enforces access).
# Supabase Dashboard > Project Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Bypasses RLS. NEVER expose to the browser.
# Supabase Dashboard > Project Settings > API > Project API keys > service_role
SUPABASE_SERVICE_ROLE_KEY=

# Base URL of this app (used for auth redirects). Local default below.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional, SERVER ONLY. If set, enables AI Vision trait suggestions on the
# report form (Gemini analyses ONLY the uploaded photo — never location,
# contact, or identity). The app is FULLY functional without this key; when
# it is absent the "Suggest traits with AI" control simply doesn't appear and
# reporters fill traits in manually. Never exposed to the browser.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
