{
  "name": "pawpin",
  "version": "0.1.0",
  "private": true,
  "description": "PawPin — Drop a Pin, Save a Stray. A location-based community app to report and coordinate care for stray cats.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
